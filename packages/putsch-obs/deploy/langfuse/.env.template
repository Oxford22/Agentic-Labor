# Putsch Langfuse self-host — environment template.
#
# Copy to `.env` and fill. Never commit. The deploy pipeline reads this
# file through age-decrypt; see deploy/langfuse/terraform/.
#
# All values MUST be set before `docker compose up` succeeds. The variable
# expansions in docker-compose.yml carry `:?` markers that fail loudly.

# ─────────────────────────────────────────────────────────────────────────────
# Langfuse server
# ─────────────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://langfuse.putsch.internal
NEXTAUTH_SECRET=                            # `openssl rand -base64 32`
SALT=                                       # `openssl rand -base64 32`
ENCRYPTION_KEY=                             # 64-hex-char string

# Project-level API keys (created in Langfuse UI on first boot).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Postgres (Langfuse metadata)
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=                          # `openssl rand -base64 24`
POSTGRES_DB=langfuse

# ─────────────────────────────────────────────────────────────────────────────
# Postgres (Vault — REVERSIBLE TOKENIZATION; separate DB!)
# ─────────────────────────────────────────────────────────────────────────────
VAULT_POSTGRES_USER=putsch_vault_writer
VAULT_POSTGRES_PASSWORD=
VAULT_POSTGRES_DB=putsch_vault
PUTSCH_OBS_VAULT_DSN=postgresql://putsch_vault_writer:CHANGEME@postgres-vault:5432/putsch_vault
PUTSCH_OBS_VAULT_ENCRYPTION_KEY=            # `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`

# ─────────────────────────────────────────────────────────────────────────────
# ClickHouse
# ─────────────────────────────────────────────────────────────────────────────
CLICKHOUSE_DB=langfuse
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Redis (queue)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# MinIO (S3-compat object store)
# ─────────────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=langfuse-blob
MINIO_ROOT_PASSWORD=
LANGFUSE_S3_BUCKET=langfuse-events

# ─────────────────────────────────────────────────────────────────────────────
# OTel / app
# ─────────────────────────────────────────────────────────────────────────────
PUTSCH_OBS_SERVICE_NAME=putsch-obs
PUTSCH_OBS_DEPLOYMENT_ENVIRONMENT=production-fra
PUTSCH_OBS_RETENTION_CLASS=limited_risk
PUTSCH_OBS_LANGFUSE_HOST=https://langfuse.putsch.internal
PUTSCH_OBS_OTEL_EXPORTER_ENDPOINT=http://otel-collector:4318
PUTSCH_OBS_REDACTION_MODE=strict
PUTSCH_OBS_REDACTION_LLM_ENDPOINT=http://qwen3-redactor:8000/v1
PUTSCH_OBS_REDACTION_LLM_API_KEY=local

# ─────────────────────────────────────────────────────────────────────────────
# Judge (eval-time only)
# ─────────────────────────────────────────────────────────────────────────────
PUTSCH_OBS_JUDGE_MODEL=deepseek-chat
PUTSCH_OBS_JUDGE_API_BASE=https://api.mistral.ai/v1
PUTSCH_OBS_JUDGE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Alerts (Teams via Microsoft Graph workflow webhook)
# ─────────────────────────────────────────────────────────────────────────────
PUTSCH_OBS_TEAMS_WEBHOOK_URL=
PUTSCH_OBS_ALERTS_ENABLED=true
PUTSCH_OBS_ALERTS_MIN_SEVERITY=warning
