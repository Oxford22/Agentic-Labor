# Putsch AP Crew — document layer configuration
# Copy to .env and fill in. Production values live in HashiCorp Vault.

# ----- Docling -----
PUTSCH_DOCS_DOCLING__MODEL_ID=ibm-granite/granite-docling-258M
PUTSCH_DOCS_DOCLING__DEVICE=auto
PUTSCH_DOCS_DOCLING__ARTIFACTS_PATH=/opt/docling-artifacts
PUTSCH_DOCS_DOCLING__DO_OCR=true
PUTSCH_DOCS_DOCLING__DO_TABLE_STRUCTURE=true
PUTSCH_DOCS_DOCLING__TIMEOUT_SECONDS=60

# ----- Fallback (vLLM hosting Qwen2.5-VL-72B in Frankfurt) -----
PUTSCH_DOCS_FALLBACK__ENABLED=true
PUTSCH_DOCS_FALLBACK__ENDPOINT=http://vllm.frankfurt.putsch.internal:8000/v1
PUTSCH_DOCS_FALLBACK__MODEL_ID=Qwen/Qwen2.5-VL-72B-Instruct
PUTSCH_DOCS_FALLBACK__TIMEOUT_SECONDS=120
PUTSCH_DOCS_FALLBACK__MAX_RETRIES=3
PUTSCH_DOCS_FALLBACK__BREAKER_FAIL_MAX=5
PUTSCH_DOCS_FALLBACK__BREAKER_RESET_SECONDS=60

# ----- Confidence thresholds -----
PUTSCH_DOCS_CONFIDENCE__FALLBACK_THRESHOLD=0.85
PUTSCH_DOCS_CONFIDENCE__CRITICAL_FIELD_THRESHOLD=0.90
PUTSCH_DOCS_CONFIDENCE__ARITHMETIC_TOLERANCE_CENTS=2
PUTSCH_DOCS_CONFIDENCE__JUDGE_CRITICAL_FIELDS_ALWAYS=true

# ----- Extraction LLM (Mistral La Plateforme, EU) -----
PUTSCH_DOCS_LLM__MODEL=mistral/mistral-large-latest
PUTSCH_DOCS_LLM__API_BASE=https://api.mistral.ai/v1
PUTSCH_DOCS_LLM__API_KEY=        # required
PUTSCH_DOCS_LLM__JUDGE_MODEL=mistral/mistral-medium-latest
PUTSCH_DOCS_LLM__TEMPERATURE=0.0
PUTSCH_DOCS_LLM__MAX_TOKENS=4096

# ----- Observability -----
PUTSCH_DOCS_OBS__LANGFUSE_ENABLED=true
PUTSCH_DOCS_OBS__LANGFUSE_HOST=https://langfuse.frankfurt.putsch.internal
PUTSCH_DOCS_OBS__LANGFUSE_PUBLIC_KEY=
PUTSCH_DOCS_OBS__LANGFUSE_SECRET_KEY=
PUTSCH_DOCS_OBS__REDACT_PII_IN_LOGS=true
PUTSCH_DOCS_OBS__LOG_LEVEL=INFO
PUTSCH_DOCS_OBS__SERVICE_NAME=putsch-docs
PUTSCH_DOCS_OBS__ENVIRONMENT=prod
